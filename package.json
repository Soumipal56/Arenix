{
  "name": "arenix-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Root workspace to orchestrate builds and testing for Arenix",
  "scripts": {
    "build:backend": "npm run build --prefix Backend",
    "build:frontend": "npm run build --prefix Frontend",
    "build:all": "npm run build:backend && npm run build:frontend",
    "start": "npm start --prefix Backend",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.7.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  }
}
